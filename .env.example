# ── Registration Form ──────────────────────────────────────────────────────────
# Formspree receives form submissions and emails them to you (free tier: 50/mo)
# 1. Go to https://formspree.io and sign up free
# 2. Click "New Form", give it a name, copy the Form ID (e.g. xpwzabcd)
# 3. Add it below — applications will be emailed to your Formspree account email
NEXT_PUBLIC_FORMSPREE_ID=xpwzabcd

# ── Ad Networks ────────────────────────────────────────────────────────────────
# TrafficJunky — https://www.trafficjunky.com
NEXT_PUBLIC_TJ_PUBLISHER_ID=123456
NEXT_PUBLIC_TJ_ZONE_BANNER=789012
NEXT_PUBLIC_TJ_ZONE_RECT=789013

# ExoClick — https://www.exoclick.com
NEXT_PUBLIC_USE_EXOCLICK=false
NEXT_PUBLIC_EXO_ZONE_BANNER=4000000
NEXT_PUBLIC_EXO_ZONE_RECT=4000001
