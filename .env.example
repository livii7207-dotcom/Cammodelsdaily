# Email — model application forms are sent here
# Any SMTP provider works: Gmail, SendGrid, Mailgun, etc.
# Gmail: use an App Password (not your real password) — https://myaccount.google.com/apppasswords
CONTACT_EMAIL=you@cammodelsdaily.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password

# Stripe Connect — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_SITE_URL=https://cammodelsdaily.com

# ── Ad Networks ────────────────────────────────────────────────────────────────
# Use TrafficJunky, ExoClick, or both (different slots can use different networks)

# TrafficJunky — https://www.trafficjunky.com
# 1. Sign up and create a publisher account
# 2. Create ad zones (pick sizes: 728x90 banner, 300x250 rectangle, etc.)
# 3. Copy your Publisher ID and Zone IDs below
NEXT_PUBLIC_TJ_PUBLISHER_ID=123456
NEXT_PUBLIC_TJ_ZONE_BANNER=789012      # 728x90 leaderboard (top of page)
NEXT_PUBLIC_TJ_ZONE_RECT=789013        # 300x250 rectangle (mid page)

# ExoClick — https://www.exoclick.com
# 1. Sign up, go to Zones > Add Zone > choose Banner format
# 2. Set the domain to cammodelsdaily.com, pick a size, save
# 3. Copy the Zone ID shown in your dashboard
NEXT_PUBLIC_USE_EXOCLICK=false
NEXT_PUBLIC_EXO_ZONE_BANNER=4000000    # 728x90 banner zone ID
NEXT_PUBLIC_EXO_ZONE_RECT=4000001      # 300x250 rectangle zone ID
